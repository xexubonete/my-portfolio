---
import Card from '../Card.astro'
import Pulse from '../Pulse.astro'
---

<Card colSpan="md:col-span-1 lg:col-span-1" rowSpan="md:row-span-2 lg:row-span-2" title="Ocupado">
  <div class="mb-2 flex w-full items-start justify-between">
    <div class="flex flex-col">
      <span class="cursor-pointer text-xs text-gray-500"
        >Pero puedes contactarme...
      </span>
    </div>
    <Pulse />
  </div>
  <br />
  <p class="text-sm">Actualmente trabajo en Cafler</p>
</Card>
