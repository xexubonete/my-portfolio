---
import BaseLayout from '../../layouts/BaseLayout.astro'
import TopLayout from '../../layouts/TopLayout.astro'
import BottomLayout from '../../layouts/BottomLayout.astro'
import { WORK, SPANISH } from '../../lib/constants-es'

// Agrupa etapas consecutivas en la misma empresa (p. ej. los 3 puestos de NTT DATA).
type Role = (typeof SPANISH)[number]
const groups: { company: string; link?: string; roles: Role[] }[] = []
for (const role of SPANISH) {
  const last = groups[groups.length - 1]
  if (last && last.company === role.company) last.roles.push(role)
  else groups.push({ company: role.company, link: role.link, roles: [role] })
}
---

<BaseLayout lang="es" title={WORK.TITLE} description={WORK.DESCRIPTION}>
  <main class="flex min-h-[80vh] flex-auto flex-col" transition:animate="fade">
    <TopLayout>
      <h2
        class="js-exp-title scroll-m-20 border-b pb-2 text-3xl font-semibold tracking-tight first:mt-0"
      >
        {WORK.TITLE}
      </h2>
    </TopLayout>
    <BottomLayout>
      <ul>
        {
          groups.map((group) => (
            <li class="animate mt-4 border-b border-black/10 py-8 first-of-type:mt-0 first-of-type:pt-0 last-of-type:border-none dark:border-white/25">
              <a
                href={group.link ?? ''}
                target="_blank"
                rel="noreferrer"
                class={`text-lg font-bold ${group.link ? 'text-primary' : 'text-foreground'}`}
              >
                {group.company}
              </a>
              <div class="mt-3 space-y-5 border-l-2 border-black/10 pl-4 dark:border-white/15">
                {group.roles.map((role) => (
                  <div>
                    <div class="text-xs uppercase text-muted-foreground">
                      {role.start} - {role.end}
                    </div>
                    <div class="text-sm font-semibold">{role.position}</div>
                    <p class="mt-1 text-sm italic text-muted-foreground">
                      {role.description}
                    </p>
                    <ul class="mt-2 list-disc pl-5 text-sm">
                      {role.responsibilities.map((i) => (
                        <li>{i}</li>
                      ))}
                    </ul>
                    <p class="mt-2 text-sm text-muted-foreground">
                      <span class="font-semibold text-foreground">Stack:</span>{' '}
                      {role.stack.join(' · ')}
                    </p>
                  </div>
                ))}
              </div>
            </li>
          ))
        }
      </ul>
    </BottomLayout>
  </main>
</BaseLayout>
