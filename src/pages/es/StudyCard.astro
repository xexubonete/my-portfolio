---
import Card from '../Card.astro'
import { Badge } from '../ui/_badge'
import { STUDIES } from '../../lib/constants-es'
---

<Card colSpan="lg:col-span-1" rowSpan="lg:row-span-1" colStart="lg:col-start-3" rowStart="lg:row-start-8" title="Aprendizaje">
  <div class="mt-2 flex w-full flex-wrap items-center justify-center gap-2">
    {
      STUDIES.map((study) => (
        <a href={study.link} target="__blank">
          <Badge variant="outline">{study.institution}</Badge>
        </a>
      ))
    }
  </div>
</Card>
