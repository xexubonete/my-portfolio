---
import Card from '../Card.astro'
import { Button } from '../ui/_button'
import { SPANISH } from '../../lib/constants-es'
---

<Card
  colSpan="lg:col-span-1"
  rowSpan="lg:row-span-2"
  colStart="lg:col-start-2"
  rowStart="lg:row-start-7"
  title="Experiencia (+4a)"
>
  <div class="mt-2 space-y-4">
    {
      SPANISH.slice(0, 3).map((exp) => {
        const isNttDotnetRole =
          exp.company === 'NTT DATA' && exp.position === '.NET Developer'
        const start = isNttDotnetRole ? '2022' : exp.start
        const end = exp.end

        return (
          <div>
            <h3 class="truncate text-base font-semibold">{exp.position}</h3>
            <a class="text-sm text-primary" href={exp?.link ?? ''}>
              {exp.company}
            </a>
            <p class="text-sm text-gray-600">
              {start} - {end}
            </p>
          </div>
        )
      })
    }
    <a href="/es/work">
      <Button variant="link" className="pl-0"> Ver más </Button>
    </a>
  </div>
</Card>
