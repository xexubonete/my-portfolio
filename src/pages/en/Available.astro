---
import Card from '../Card.astro'
import Pulse from '../Pulse.astro'
---

<Card
  colSpan="lg:col-span-1"
  rowSpan="lg:row-span-1"
  colStart="lg:col-start-2"
  rowStart="lg:row-start-3"
  title="Blocked"
>
  <div class="mb-2 flex w-full items-start justify-between">
    <div class="flex flex-col">
      <span class="cursor-pointer text-xs text-gray-500"
        >But you can contact me...
      </span>
    </div>
    <Pulse />
  </div>
  <br />
  <p class="text-sm">Currently working at Cafler</p>
</Card>
