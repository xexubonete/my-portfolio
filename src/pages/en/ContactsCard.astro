---
import { buttonVariants } from '../ui/_button'
import Card from '../Card.astro'
import { LINKS } from '../../lib/constants'
---

<Card colSpan="lg:col-span-1" rowSpan="lg:row-span-4" colStart="lg:col-start-4" rowStart="lg:row-start-6">
  <div class="h-full">
    <address class="mt-4 flex flex-col" style="margin-top: -10px;">
      <p>
        <div class="text-right">
          <a
            class={buttonVariants({ variant: 'outline' })}
            style="margin-top:18px"
            href="tel:+34722243881"
            target="_blank"
            rel="noreferrer"
          >
            🤙 Call me
          </a>
        </div>
        <div class="text-left">
          <a
            class={buttonVariants({ variant: 'outline' })}
            style="margin-top:10px"
            href="mailto:xexubonete@gmail.com"
          >
            Email me 📧
          </a>
        </div>
        <div class="text-right">
          <a
            class={buttonVariants({ variant: 'outline' })}
            class="text-sm"
            style="margin-top:5px"
            href={LINKS.linkedin}
            target="_blank">👔LinkedIn</a
          >
        </div>
        <div class="text-left">
          <a
            class={buttonVariants({ variant: 'outline' })}
            class="text-sm"
            style="margin-top:5px;"
            href={LINKS.github}
            target="_blank">Github🎖️</a
          >
        </div>
      </p>
    </address>
    <div class="flex h-full w-full flex-col">
      <div>
        <img
          width="90"
          height="90"
          src="/me_chillin.png"
          class="pointer-events-none absolute bottom-[-20px] right-[-110px] z-[-1] max-h-[300px] w-auto select-none opacity-50 lg:relative lg:bottom-auto lg:right-auto lg:z-auto lg:opacity-100"
          alt="memoji of xexu taking easy"
        />
      </div>
    </div>
  </div>
</Card>
