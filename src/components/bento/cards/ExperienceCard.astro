---
import Card from '../Card.astro'
import { Button } from '@/components/ui/_button'
import { experienceByLang, yearsOfExperience } from '@/i18n'
import type { Lang } from '@/i18n'

interface Props {
  lang: Lang
  span?: string
}

const { lang, span } = Astro.props
const experience = experienceByLang[lang]

// Group consecutive roles at the same company (NTT DATA = 3 stages) so the card
// shows the company once with its full date range (e.g. 02/2022 – 05/2024).
type Role = (typeof experience)[number]
const groups: { company: string; link?: string; roles: Role[] }[] = []
for (const role of experience) {
  const last = groups[groups.length - 1]
  if (last && last.company === role.company) last.roles.push(role)
  else groups.push({ company: role.company, link: role.link, roles: [role] })
}

const { years, exact } = yearsOfExperience()
const yearsLabel = `${exact ? '' : '+'}${years}`

const strings = {
  es: { title: `Experiencia (${yearsLabel}a)`, viewMore: 'Ver más' },
  en: { title: `Experience (${yearsLabel}yr)`, viewMore: 'View More' },
}[lang]
---

<Card span={span} title={strings.title} class="js-exp-card">
  <div class="mt-2 flex flex-1 flex-col justify-between gap-4">
    {
      groups.slice(0, 3).map((group) => (
        <div>
          <h3 class="truncate text-base font-semibold">
            {group.roles[0].position}
          </h3>
          <a
            class="text-sm text-primary"
            href={group.link ?? ''}
            target="_blank"
            rel="noreferrer"
          >
            {group.company}
          </a>
          <p class="text-sm text-muted-foreground">
            {group.roles[group.roles.length - 1].start} – {group.roles[0].end}
          </p>
        </div>
      ))
    }
    <a href={`/${lang}/work`}>
      <Button variant="link" className="pl-0">{strings.viewMore}</Button>
    </a>
  </div>
</Card>
