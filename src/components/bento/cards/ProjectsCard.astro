---
import Card from '../Card.astro'
import { PROJECT_LINKS } from '@/i18n'
import type { Lang } from '@/i18n'
import { ArrowUpRight } from 'lucide-react'

interface Props {
  lang: Lang
  span?: string
}

const { lang, span } = Astro.props
const title = lang === 'es' ? 'Proyectos' : 'Projects'
---

<Card span={span} title={title}>
  <div class="mt-4 grid grid-cols-2 gap-3">
    {
      PROJECT_LINKS.map((project) => (
        <a
          class={`repo-btn ${project.outline ? 'repo-btn--live' : ''}`}
          href={project.href}
          target="_blank"
          rel="noreferrer"
          title={
            project.outline
              ? lang === 'es'
                ? 'Estás aquí'
                : 'You are here'
              : undefined
          }
        >
          {project.outline ? (
            <span class="portfolio-live" aria-hidden="true" />
          ) : (
            <svg
              class="h-3.5 w-3.5 shrink-0"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path d="M12 2A10 10 0 0 0 2 12c0 4.42 2.87 8.17 6.84 9.5.5.09.66-.22.66-.48v-1.7c-2.78.6-3.37-1.34-3.37-1.34-.45-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.89 1.52 2.34 1.08 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.94 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.65 0 0 .84-.27 2.75 1.02a9.5 9.5 0 0 1 5 0c1.91-1.29 2.75-1.02 2.75-1.02.55 1.38.2 2.4.1 2.65.64.7 1.03 1.59 1.03 2.68 0 3.84-2.34 4.69-4.57 4.94.36.31.68.92.68 1.85v2.74c0 .27.16.58.67.48A10 10 0 0 0 22 12 10 10 0 0 0 12 2z" />
            </svg>
          )}
          <span class="truncate">{project.label}</span>
          <ArrowUpRight
            className="repo-arrow h-3.5 w-3.5 shrink-0"
            aria-hidden="true"
          />
        </a>
      ))
    }
  </div>
</Card>
